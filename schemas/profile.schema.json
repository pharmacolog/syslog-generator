{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pharmacolog/syslog-generator/schemas/profile.schema.json",
  "title": "syslog-generator profile",
  "description": "Схема профиля нагрузки для syslog-generator (D3, v8.5.0; F17, v9.4.0 — добавлены anomalies). Семантические правила проверяются рантайм-валидатором validate.rs; эта схема ловит только структурные ошибки.",
  "type": "object",
  "$defs": {
    "TargetConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["address", "transport"],
      "properties": {
        "address": { "type": "string", "minLength": 1 },
        "transport": { "type": "string", "enum": ["tcp", "udp", "tls", "file"] },
        "connections": { "type": "integer", "minimum": 1, "default": 1 },
        "weight": { "type": "integer", "minimum": 0, "default": 1 },
        "framing": { "type": "string", "enum": ["non-transparent", "octet-counting", "octet_counting", "octet"], "default": "non-transparent" },
        "tls_domain": { "type": ["string", "null"], "minLength": 1 },
        "tls_ca_file": { "type": ["string", "null"], "minLength": 1 },
        "tls_insecure": { "type": "boolean", "default": false },
        "tls_client_cert_file": { "type": ["string", "null"], "minLength": 1 },
        "tls_client_key_file": { "type": ["string", "null"], "minLength": 1 },
        "tls_min_protocol_version": { "type": ["string", "null"], "enum": ["1.2", "1.3", null] }
      }
    },
    "SyslogConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "facility": { "type": "integer", "minimum": 0, "maximum": 23, "default": 1 },
        "severity": { "type": "integer", "minimum": 0, "maximum": 7, "default": 6 },
        "hostname": { "type": "string", "default": "{{hostname}}" },
        "app_name": { "type": "string", "default": "syslog-generator" },
        "procid": { "type": "string", "default": "-" },
        "msgid": { "type": "string", "default": "-" },
        "structured_data": { "type": "string", "default": "-" },
        "bom": { "type": "boolean", "default": false }
      }
    },
    "ShutdownConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["drain", "immediate"], "default": "drain" },
        "drain_timeout_secs": { "type": "integer", "minimum": 0, "default": 15 }
      }
    },
    "ProtobufSchemaFieldMap": {
      "oneOf": [
        { "type": "null" },
        { "type": "object", "additionalProperties": false, "properties": { "fields": { "type": "object", "additionalProperties": { "type": "string" } } } }
      ]
    },
    "LoadShape": {
      "oneOf": [
        { "type": "null" },
        { "type": "object", "additionalProperties": false, "required": ["type"], "properties": { "type": { "const": "constant" }, "rate": { "type": "number", "minimum": 0 } } },
        { "type": "object", "additionalProperties": false, "required": ["type"], "properties": { "type": { "const": "linear" }, "start_rate": { "type": "number", "minimum": 0 }, "end_rate": { "type": "number", "minimum": 0 } } },
        { "type": "object", "additionalProperties": false, "required": ["type"], "properties": { "type": { "const": "sine" }, "min_rate": { "type": "number", "minimum": 0 }, "max_rate": { "type": "number", "minimum": 0 }, "period_secs": { "type": "number", "exclusiveMinimum": 0 } } },
        { "type": "object", "additionalProperties": false, "required": ["type"], "properties": { "type": { "const": "burst" }, "base_rate": { "type": "number", "minimum": 0 }, "burst_rate": { "type": "number", "minimum": 0 }, "every_secs": { "type": "number", "exclusiveMinimum": 0 }, "burst_secs": { "type": "number", "minimum": 0 } } }
      ]
    },
    "Anomaly": {
      "description": "F17 (v9.4.0): сценарий аномалии (тегируется полем type).",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "burst-injection" },
            "rate_multiplier": { "type": "number", "exclusiveMinimum": 0 },
            "interval_secs": { "type": "number", "exclusiveMinimum": 0 },
            "duration_secs": { "type": "number", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "slow-drip" },
            "rate_divisor": { "type": "number", "exclusiveMinimum": 1 },
            "duration_secs": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "packet-loss" },
            "loss_percent": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        }
      ]
    },
    "Phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "duration_secs": { "type": "integer", "minimum": 0, "default": 0 },
        "messages_per_second": { "type": "integer", "minimum": 0, "default": 0 },
        "total_messages": { "type": ["integer", "null"], "minimum": 1 },
        "templates": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "templates_file": { "type": ["string", "null"], "minLength": 1 },
        "schema_file": { "type": ["string", "null"], "minLength": 1 },
        "format": { "type": ["string", "null"], "enum": ["rfc5424", "rfc3164", "raw", "protobuf", null] },
        "output": { "type": ["string", "null"], "minLength": 1 },
        "seed": { "type": ["integer", "null"], "minimum": 0 },
        "protobuf_schema": { "$ref": "#/$defs/ProtobufSchemaFieldMap" },
        "syslog": { "$ref": "#/$defs/SyslogConfig" },
        "load_shape": { "$ref": "#/$defs/LoadShape" },
        "anomalies": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/Anomaly" },
          "description": "F17 (v9.4.0): сценарии аномалий нагрузки (burst-injection, slow-drip, packet-loss)."
        },
        "template_weights": { "type": ["array", "null"], "items": { "type": "number" } },
        "pad_to_bytes": { "type": ["integer", "null"], "minimum": 1 }
      },
      "anyOf": [
        { "required": ["templates"] },
        { "required": ["templates_file"] },
        { "required": ["schema_file"] }
      ]
    },
    "Distribution": {
      "type": "string",
      "enum": ["round-robin", "broadcast", "weighted"]
    }
  },
  "additionalProperties": false,
  "properties": {
    "targets": { "type": "array", "items": { "$ref": "#/$defs/TargetConfig" } },
    "distribution": { "$ref": "#/$defs/Distribution" },
    "shutdown": { "$ref": "#/$defs/ShutdownConfig" },
    "phases": { "type": "array", "items": { "$ref": "#/$defs/Phase" }, "minItems": 1 },
    "metrics_addr": { "type": ["string", "null"] }
  }
}