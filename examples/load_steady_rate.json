{
  "targets": [
    { "address": "/tmp/syslog_load.log", "transport": "file", "connections": 1, "weight": 1 }
  ],
  "distribution": "round-robin",
  "shutdown": { "mode": "drain", "drain_timeout_secs": 10 },
  "phases": [
    {
      "name": "steady_200rps",
      "messages_per_second": 200,
      "total_messages": 500,
      "templates": ["load seq={{sequence}} app={{real_app}} host={{real_hostname}}"]
    },
    {
      "name": "timed_100rps_5s",
      "messages_per_second": 100,
      "duration_secs": 5,
      "templates": ["timed seq={{sequence}} pid={{pid}}"]
    }
  ]
}
