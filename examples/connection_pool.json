{
  "targets": [
    { "address": "127.0.0.1:6514", "transport": "tcp", "connections": 8, "weight": 1 }
  ],
  "distribution": "round-robin",
  "shutdown": { "mode": "drain", "drain_timeout_secs": 15 },
  "phases": [
    {
      "name": "pool-load",
      "messages_per_second": 5000,
      "duration_secs": 30,
      "templates": ["load seq={{sequence}} host={{hostname}}"]
    }
  ]
}
