{
  "fields": {
    "timestamp": {"type": "datetime", "format": "rfc3339"},
    "client_ip": {"type": "faker", "faker": "ipv4"},
    "method": {"type": "enum", "values": ["GET", "POST", "PUT", "DELETE", "PATCH"]},
    "path": {"type": "enum", "values": ["/api/v1/users", "/index.html", "/health", "/var/log"]},
    "status": {"type": "int", "min": 200, "max": 599},
    "user_agent": {"type": "faker", "faker": "user_agent"},
    "request_id": {"type": "faker", "faker": "uuid"}
  },
  "template": "{{timestamp}} {{client_ip}} {{method}} {{path}} {{status}} "{{user_agent}}" {{request_id}}"
}
